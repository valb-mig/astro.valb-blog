---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import Tag from '../../components/Tag.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Sort by date desc
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all tags
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

// Active tag filter from URL
const activeTag = Astro.url.searchParams.get('tag');
const filtered = activeTag
  ? posts.filter((p) => p.data.tags.includes(activeTag))
  : posts;
---

<Base title="blog — ~/blog">
  <div style="max-width: 72rem; margin: 0 auto; padding: 5rem 1.5rem 8rem;">

    <!-- Header -->
    <div style="margin-bottom: 3rem;">
      <p style="font-size: 0.75rem; color: var(--subtle); margin-bottom: 0.5rem;">
        ❯ ls -la blog/ | sort -k6 -r
      </p>
      <h1 style="font-size: 1.75rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem;">
        # blog
      </h1>
      <p style="font-size: 0.8125rem; color: var(--subtle);">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
        {activeTag && ` → filtrado por #${activeTag}`}
      </p>
    </div>

    <!-- Tag filters -->
    {allTags.length > 0 && (
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 2.5rem;">
        <a
          href="/blog"
          style={`
            display: inline-block;
            font-size: 0.7rem; font-family: inherit;
            padding: 0.15em 0.55em;
            border-radius: 2px;
            border: 1px solid ${!activeTag ? 'var(--accent)' : 'var(--border)'};
            color: ${!activeTag ? 'var(--accent)' : 'var(--muted)'};
            background: var(--surface);
            transition: border-color 0.2s, color 0.2s;
          `}
        >
          all
        </a>
        {allTags.map((tag) => (
          <Tag tag={tag} href={`/blog?tag=${tag}`} active={activeTag === tag} />
        ))}
      </div>
    )}

    <!-- Post list -->
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      {filtered.length > 0
        ? filtered.map((post, i) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.slug}
              tags={post.data.tags}
              project={post.data.project}
              newsletter={post.data.newsletter}
              delay={i * 60}
            />
          ))
        : (
          <p style="color: var(--subtle); font-size: 0.875rem;">
            nenhum post encontrado para #{activeTag}.
          </p>
        )
      }
    </div>
  </div>
</Base>
