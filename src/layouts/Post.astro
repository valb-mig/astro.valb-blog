---
import Base from './Base.astro';
import Tag from '../components/Tag.astro';
import { getEntry } from 'astro:content';

const { frontmatter } = Astro.props;
const { title, description, date, tags = [], project, newsletter } = frontmatter;

const dateStr = new Date(date).toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Fetch linked project if it exists
const linkedProject = project
  ? await getEntry('projects', project).catch(() => null)
  : null;
---

<Base title={title} description={description} og={{ type: 'article' }}>
  <article style="max-width: 72rem; margin: 0 auto; padding: 6rem 1.5rem 8rem;">

    <!-- Breadcrumb -->
    <p style="font-size: 0.75rem; color: var(--subtle); margin-bottom: 2rem;">
      <a href="/" style="color: var(--accent);">~</a>
      <span style="color: var(--subtle);"> / </span>
      <a href="/blog" style="color: var(--muted);">blog</a>
      <span style="color: var(--subtle);"> / </span>
      <span style="color: var(--muted);">{title.toLowerCase().replaceAll(' ', '-')}</span>
    </p>

    <!-- Header -->
    <header style="margin-bottom: 3rem; border-bottom: 1px solid var(--border); padding-bottom: 2rem;">
      <p style="font-size: 0.75rem; color: var(--subtle); margin-bottom: 0.75rem;">
        ❯ cat {title.toLowerCase().replaceAll(' ', '-')}.md
      </p>
      <h1 style="font-size: 2rem; font-weight: 700; color: var(--text); margin-bottom: 1rem; line-height: 1.3;">
        # {title}
      </h1>
      <p style="color: var(--muted); margin-bottom: 1.25rem;">{description}</p>

      <!-- Meta row -->
      <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; font-size: 0.75rem; color: var(--subtle);">
        <span>{dateStr}</span>
        {newsletter && (
          <span style="color: var(--accent); border: 1px solid var(--accent); padding: 0.1em 0.5em; border-radius: 2px;">
            #newsletter
          </span>
        )}
        {linkedProject && (
          <a
            href={`/projects/${project}`}
            style="display: inline-flex; align-items: center; gap: 0.35rem; color: var(--muted); border: 1px solid var(--border); padding: 0.15em 0.6em; border-radius: 2px; transition: border-color 0.2s, color 0.2s;"
            onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)';"
            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)';"
          >
            ⬡ {linkedProject.data.title}
          </a>
        )}
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
          {tags.map((tag: string) => <Tag tag={tag} />)}
        </div>
      )}
    </header>

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Back link -->
    <div style="margin-top: 4rem; border-top: 1px solid var(--border); padding-top: 2rem;">
      <a
        href="/blog"
        style="font-size: 0.875rem; color: var(--muted); transition: color 0.2s;"
        onmouseover="this.style.color='var(--accent)';"
        onmouseout="this.style.color='var(--muted)';"
      >
        ← back to blog
      </a>
    </div>
  </article>
</Base>
