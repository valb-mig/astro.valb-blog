---
const navItems = [
  { label: 'blog', href: '/blog' },
  { label: 'projects', href: '/projects' },
  { label: 'about', href: '/about' },
];

const current = Astro.url.pathname;
---

<header
  style="
    position: sticky; top: 0; z-index: 100;
    height: 3.5rem;
    border-bottom: 1px solid var(--border);
    background: rgba(9, 9, 11, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  "
>
  <div
    style="
      max-width: 72rem; margin: 0 auto;
      padding: 0 1.5rem;
      height: 100%;
      display: flex; align-items: center; justify-content: space-between;
    "
  >
    <!-- Logo / home link -->
    <a href="/" style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem;">
      <span style="color: var(--accent);">~/</span>
      <span style="color: var(--text); font-weight: 700;">blog</span>
      <span class="cursor-blink" style="color: var(--accent); font-weight: 700;">▋</span>
    </a>

    <!-- Nav -->
    <nav style="display: flex; align-items: center; gap: 2rem;">
      {navItems.map(({ label, href }) => {
        const isActive = current === href || current.startsWith(href + '/');
        return (
          <a
            href={href}
            style={`
              font-size: 0.8125rem;
              color: ${isActive ? 'var(--accent)' : 'var(--muted)'};
              transition: color 0.2s;
              position: relative;
            `}
          >
            {isActive && <span style="color: var(--subtle); margin-right: 0.3rem;">❯</span>}
            {label}
          </a>
        );
      })}

      <!-- RSS link -->
      <a
        href="/rss.xml"
        title="RSS Feed"
        style="color: var(--subtle); transition: color 0.2s; font-size: 0.75rem;"
        onmouseover="this.style.color='var(--accent)';"
        onmouseout="this.style.color='var(--subtle)';"
      >
        rss
      </a>
    </nav>
  </div>
</header>
