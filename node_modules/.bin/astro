#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/astro@5.18.1_rollup@4.59.0_typescript@5.9.3/node_modules/astro/node_modules:/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/astro@5.18.1_rollup@4.59.0_typescript@5.9.3/node_modules:/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/astro@5.18.1_rollup@4.59.0_typescript@5.9.3/node_modules/astro/node_modules:/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/astro@5.18.1_rollup@4.59.0_typescript@5.9.3/node_modules:/home/valb/Projects/astro.valb-blog/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../astro/astro.js" "$@"
else
  exec node  "$basedir/../astro/astro.js" "$@"
fi
